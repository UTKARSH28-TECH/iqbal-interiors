{
  "name": "iqbal-interiors",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "gallery:manifest": "node scripts/build-gallery-manifest.mjs",
    "videos:manifest": "node scripts/build-video-manifest.mjs",
    "manifests": "npm run gallery:manifest && npm run videos:manifest",
    "predev": "npm run manifests",
    "dev": "next dev",
    "prebuild": "npm run manifests",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "preview": "npm run manifests && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "npm run manifests && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.0",
    "image-size": "^2.0.2",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.105.0"
  }
}
